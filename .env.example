# The migration bridge is zero-auth and needs nothing here. This file
# exists only as a template for developers who want to extend this
# quickstart by calling authenticated /v1/company/* endpoints. Sign up
# at https://apier.no to get a key.
APIER_API_KEY=

# Optional: override the apier.no base URL for testing (defaults to the
# canonical production host inside the example scripts themselves).
# APIER_BASE_URL=
